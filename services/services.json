{
  "services": [
    {
      "service_id": 1,
      "service_name": "Harambee Members Portal",
      "service_host": "selfservice.harambeesacco.com",
      "service_port": 443,
      "service_resource_uri": "/",
      "service_method": "GET",
      "monitoring_interval": 10,
      "monitoring_interval_unit": "Minutes",
      "enable_file_logging": true,
      "file_logging_interval": "Hourly",
      "enable_logs_archiving": true,
      "log_archiving_interval": "Weekly",
      "archive_format": ".gzip"
    },
    {
      "service_id": 2,
      "service_name": "Sky World Services Portal",
      "service_host": "portal.skyworld.co.ke",
      "service_port": 443,
      "service_resource_uri": "/",
      "service_method": "GET",
      "monitoring_interval": 30,
      "monitoring_interval_unit": "Seconds",
      "enable_file_logging": false,
      "file_logging_interval": "Daily",
      "enable_logs_archiving": false,
      "log_archiving_interval": "Weekly",
      "archive_format": ".gzip"
    }
  ]
}